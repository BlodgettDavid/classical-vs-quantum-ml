# Python cache
__pycache__/
*.pyc

# OS junk
.DS_Store
Thumbs.db

# Logs (ignore any .log files globally)
*.log

# Environment variables
.env

# Jupyter checkpoints and scratch notebooks
.ipynb_checkpoints/
Untitled.ipynb
scratch*.ipynb

# Build artifacts (future-proofing)
build/
dist/
*.egg-info/

# IDE/editor settings
.vscode/
.idea/

# Personal notes (keep private)
docs/notes_scratch.txt
# Optional: ignore instructor notes if private
# docs/Notes.txt

# Keep directories but ignore contents
plots/*
!plots/.gitkeep
results/*
!results/.gitkeep

# Docker runtime artifacts
*.pid
*.sock

# Local virtual environment (precautionary)
.venv/